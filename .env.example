# Required
JELLYFIN_API_KEY=
# Free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Torrent client: "transmission" or "qbittorrent"
TORRENT_CLIENT=transmission

# Transmission (if TORRENT_CLIENT=transmission)
# TRANSMISSION_BASE=http://localhost:9091/transmission/rpc
# TRANSMISSION_USER=
# TRANSMISSION_PASS=

# qBittorrent (if TORRENT_CLIENT=qbittorrent)
# QBIT_BASE=http://localhost:8080/api/v2
# QBIT_USER=
# QBIT_PASS=

# Optional (defaults shown)
# MEDIA_PATH=/data/media
# FILE_HOME=             # Defaults to current user's home directory
# WEATHER_CITY=          # e.g. "London" — leave empty to disable weather
# JELLYFIN_BASE=http://localhost:8096
